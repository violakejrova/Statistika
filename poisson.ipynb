   "source": [
    "import random\n",
    "import math\n",
    "\n",
    "t = 0\n",
    "i = 0\n",
    "T = 10\n",
    "l = 1\n",
    "\n",
    "while (T>t):\n",
    "  U = random.random()\n",
    "  X = (-1/l)*(math.log(1-U))\n",
    "  t+=X\n",
    "  i+=1\n",
    "  print(t)\n",
    "print(i)\n"
   ]
  }
